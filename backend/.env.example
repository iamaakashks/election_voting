# Database Configuration
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/nie_elections

# JWT Configuration
# IMPORTANT: Change this to a cryptographically random 32+ character string in production
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (for OTP)
# For Gmail: Enable "Less secure app access" or use App Password with 2FA
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=nie-elections@nie.ac.in

# Set to "false" in production to enable real email sending
USE_MOCK_EMAIL=true

# Redis Configuration (optional - for production OTP storage)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# Application Settings
APP_ENV=development
DEBUG=true
